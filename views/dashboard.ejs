<!-- Angir dokumenttype -->
<!DOCTYPE html>
<!-- Starter HTML med norsk språk -->
<html lang="no">
  <!-- Head-seksjonen med metadata -->
  <head>
    <!-- Tegnsett -->
    <meta charset="UTF-8" />
    <!-- Responsiv layout -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Tittel for dashbordet -->
    <title>Ditt dashbord</title>
    <!-- Kobler på CSS-fil -->
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <!-- Body-innhold -->
  <body>
    <!-- Overskrift -->
    <h1>Velkommen til dashbordet</h1>

    <!-- Viser e-post for innlogget bruker -->
    <div class="card">
      <!-- Tekstlinje som viser e-posten -->
      <p><strong>E-post:</strong> <%= user.email %></p>
      <!-- Tekstlinje som viser opprettelsestidspunkt -->
      <p><strong>Opprettet:</strong> <%= user.created_at %></p>
    </div>

    <!-- Logout-skjema (POST for å unngå utilsiktede kall) -->
    <form action="/logout" method="POST">
      <!-- Knapp for å logge ut -->
      <button type="submit" class="danger">Logg ut</button>
    </form>
  </body>
</html>