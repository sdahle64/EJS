<script>
  // Stjerner og kommentarer for hver film
  document.querySelectorAll('.movie-card').forEach(card => {
    const stars = card.querySelectorAll('.star');
    const movieId = card.dataset.movieId; // klar for database senere
    let rating = 0;

    stars.forEach(star => {
      star.addEventListener('click', () => {
        rating = star.dataset.value;
        stars.forEach(s => s.style.color = s.dataset.value <= rating ? '#FFD700' : '#ccc');

        // TODO: send rating til database med movieId
        console.log(`Rating for film ${movieId}: ${rating}`);
      });
    });

    const button = card.querySelector('button');
    const textarea = card.querySelector('textarea');
    const commentList = card.querySelector('.comment-list');

    button.addEventListener('click', () => {
      const comment = textarea.value.trim();
      if(comment) {
        const li = document.createElement('li');
        li.textContent = comment;
        commentList.appendChild(li);
        textarea.value = "";

        // TODO: send comment til database med movieId
        console.log(`Kommentar for film ${movieId}: ${comment}`);
      }
    });
  });
</script>

